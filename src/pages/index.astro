---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const allPosts = await getCollection('blog', ({ data }) => data.status === 'published');
const sorted = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const VENUE_CATS    = ['venue-marketing', 'hospo-operations', 'off-peak-revenue', 'local-seo'];
const DINER_CATS    = ['diner-deals'];
const INDUSTRY_CATS = ['industry-news', 'platform-comparison'];
const STORY_CATS    = ['localfeed-story'];

const [featured] = sorted;
const venuePosts    = sorted.filter(p => VENUE_CATS.includes(p.data.category)).slice(0, 7);
const dinerPosts    = sorted.filter(p => DINER_CATS.includes(p.data.category)).slice(0, 7);
const industryPosts = sorted.filter(p => INDUSTRY_CATS.includes(p.data.category)).slice(0, 6);
const storyPosts    = sorted.filter(p => STORY_CATS.includes(p.data.category)).slice(0, 4);

const venueTotal    = sorted.filter(p => VENUE_CATS.includes(p.data.category)).length;
const dinerTotal    = sorted.filter(p => DINER_CATS.includes(p.data.category)).length;
const industryTotal = sorted.filter(p => INDUSTRY_CATS.includes(p.data.category)).length;
const storyTotal    = sorted.filter(p => STORY_CATS.includes(p.data.category)).length;

const CAT: Record<string, { label: string; color: string }> = {
  'venue-marketing':    { label: 'Venue Marketing',     color: '#E57B3C' },
  'platform-comparison':{ label: 'Platform Comparison', color: '#C0392B' },
  'off-peak-revenue':   { label: 'Off-Peak Revenue',    color: '#27AE60' },
  'hospo-operations':   { label: 'Hospo Operations',    color: '#2980B9' },
  'local-seo':          { label: 'Local SEO',           color: '#8E44AD' },
  'diner-deals':        { label: 'Diner Deals',         color: '#16A085' },
  'industry-news':      { label: 'Industry News',       color: '#555F6D' },
  'localfeed-story':    { label: 'LocalFeed Story',     color: '#E57B3C' },
};

function cat(c: string) { return CAT[c] ?? { label: c, color: '#E57B3C' }; }

const schema = {
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "LocalFeed Blog",
  "url": "https://blog.localfeed.app",
  "description": "NZ hospitality insights for venue owners and diners.",
  "publisher": { "@type": "Organization", "name": "LocalFeed", "url": "https://localfeed.co.nz" }
};
---
<Base
  title="LocalFeed Blog — NZ Hospitality Insights & Venue Marketing"
  description="Real insights for NZ restaurant, cafe, and bar owners. Venue marketing, platform comparisons, off-peak strategy, and honest operator thinking."
  schema={schema}
>

<style>
  :root {
    --cream:   #FAF8F5;
    --white:   #FFFFFF;
    --ink:     #111111;
    --muted:   #6B7280;
    --border:  #E4DFD8;
    --accent:  #E57B3C;
    --radius:  14px;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body { background: var(--cream); color: var(--ink); font-family: 'Inter', sans-serif; }

  /* ── NAV ── */
  .nav {
    position: sticky;
    top: 0;
    z-index: 200;
    background: rgba(250,248,245,0.96);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
  }
  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 60px;
    display: flex;
    align-items: center;
    gap: 2rem;
  }
  .nav-logo {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    flex-shrink: 0;
  }
  .nav-logo-text {
    font-family: 'Playfair Display', serif;
    font-size: 1.05rem;
    font-weight: 900;
    color: var(--ink);
    letter-spacing: -0.02em;
  }
  .nav-logo-sub {
    display: block;
    font-size: 0.58rem;
    color: var(--muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-family: 'JetBrains Mono', monospace;
    line-height: 1;
  }
  .nav-menu {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    flex: 1;
  }
  .nav-item {
    position: relative;
  }
  .nav-trigger {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.45rem 0.75rem;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--ink);
    cursor: pointer;
    border: none;
    background: none;
    border-radius: 8px;
    transition: background 0.15s, color 0.15s;
    white-space: nowrap;
  }
  .nav-trigger:hover { background: rgba(0,0,0,0.05); }
  .nav-trigger svg { opacity: 0.5; transition: transform 0.2s; }
  .nav-item:hover .nav-trigger svg { transform: rotate(180deg); }
  .dropdown {
    position: absolute;
    top: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%);
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: 0 12px 40px rgba(0,0,0,0.12);
    padding: 0.5rem;
    min-width: 230px;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.15s, transform 0.15s, visibility 0.15s;
    transform: translateX(-50%) translateY(-4px);
  }
  .nav-item:hover .dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }
  .dropdown-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.65rem 0.875rem;
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.12s;
  }
  .dropdown-item:hover { background: var(--cream); }
  .dropdown-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .dropdown-label {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--ink);
  }
  .dropdown-desc {
    font-size: 0.72rem;
    color: var(--muted);
    display: block;
    margin-top: 0.1rem;
  }
  .nav-spacer { flex: 1; }
  .nav-cta {
    display: inline-flex;
    align-items: center;
    padding: 0.45rem 1rem;
    background: var(--accent);
    color: white;
    font-size: 0.8rem;
    font-weight: 700;
    border-radius: 10px;
    text-decoration: none;
    white-space: nowrap;
    transition: opacity 0.15s;
    flex-shrink: 0;
  }
  .nav-cta:hover { opacity: 0.88; }
  .nav-hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    cursor: pointer;
    padding: 8px;
    border: none;
    background: none;
  }
  .nav-hamburger span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--ink);
    border-radius: 2px;
    transition: all 0.2s;
  }
  .mobile-menu {
    display: none;
    position: fixed;
    inset: 0;
    background: var(--cream);
    z-index: 300;
    padding: 1.5rem;
    overflow-y: auto;
  }
  .mobile-menu.open { display: block; }
  .mobile-close {
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid var(--border);
    background: white;
    cursor: pointer;
    font-size: 1.1rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .mobile-section { margin-bottom: 2rem; }
  .mobile-section-label {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--muted);
    margin-bottom: 0.75rem;
    font-family: 'JetBrains Mono', monospace;
  }
  .mobile-link {
    display: block;
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--border);
    font-size: 1rem;
    font-weight: 600;
    color: var(--ink);
    text-decoration: none;
    font-family: 'Playfair Display', serif;
  }

  /* ── HERO ── */
  .hero {
    padding: 5rem 1.5rem 4rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute;
    top: -120px;
    left: 50%;
    transform: translateX(-50%);
    width: 600px;
    height: 600px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(229,123,60,0.1) 0%, transparent 65%);
    pointer-events: none;
  }
  .hero-eyebrow {
    display: inline-block;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--accent);
    margin-bottom: 1.25rem;
  }
  .hero-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.5rem, 7vw, 4.5rem);
    font-weight: 900;
    color: var(--ink);
    line-height: 1.05;
    letter-spacing: -0.03em;
    max-width: 700px;
    margin: 0 auto 1.25rem;
  }
  .hero-title em { font-style: italic; color: var(--accent); }
  .hero-sub {
    font-size: 1rem;
    color: var(--muted);
    max-width: 400px;
    margin: 0 auto 2.5rem;
    line-height: 1.6;
  }
  .hero-scroll {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .scroll-section-link {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--muted);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    transition: color 0.15s;
  }
  .scroll-section-link:hover { color: var(--accent); }
  .scroll-section-link::before {
    content: '↓';
    font-size: 0.7rem;
  }

  /* ── FEATURED ── */
  .featured-wrap {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem 5rem;
  }
  .section-eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--muted);
    margin-bottom: 1rem;
  }
  .featured-card {
    display: block;
    text-decoration: none;
    background: var(--ink);
    border-radius: 20px;
    padding: 2.5rem;
    position: relative;
    overflow: hidden;
    transition: transform 0.2s;
  }
  .featured-card:hover { transform: translateY(-2px); }
  .featured-glow {
    position: absolute;
    top: -80px;
    right: -60px;
    width: 360px;
    height: 360px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(229,123,60,0.2) 0%, transparent 65%);
    pointer-events: none;
  }
  .featured-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
    border: 1px solid rgba(229,123,60,0.3);
    background: rgba(229,123,60,0.1);
    padding: 0.25rem 0.75rem;
    border-radius: 100px;
    margin-bottom: 1.25rem;
  }
  .featured-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.5rem, 3.5vw, 2.25rem);
    font-weight: 900;
    color: white;
    line-height: 1.2;
    max-width: 580px;
    margin-bottom: 0.875rem;
    letter-spacing: -0.02em;
  }
  .featured-desc {
    font-size: 0.92rem;
    color: #9CA3AF;
    max-width: 480px;
    line-height: 1.65;
    margin-bottom: 1.5rem;
  }
  .featured-read {
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--accent);
  }

  /* ── MENU SECTION ── */
  .menu-section {
    border-top: 1px solid var(--border);
    padding: 4rem 1.5rem;
  }
  .menu-section:nth-child(even) { background: var(--white); }
  .menu-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 3rem;
    align-items: start;
  }
  .menu-header { position: sticky; top: 80px; }
  .menu-tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.58rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--accent);
    margin-bottom: 0.75rem;
  }
  .menu-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.6rem;
    font-weight: 900;
    color: var(--ink);
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin-bottom: 0.75rem;
  }
  .menu-desc {
    font-size: 0.82rem;
    color: var(--muted);
    line-height: 1.65;
    margin-bottom: 1.25rem;
  }
  .menu-seeall {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--accent);
    text-decoration: none;
    border: 1px solid rgba(229,123,60,0.3);
    padding: 0.4rem 0.875rem;
    border-radius: 8px;
    transition: background 0.15s;
  }
  .menu-seeall:hover { background: rgba(229,123,60,0.07); }
  .article-list { width: 100%; }
  .article-item {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 0.75rem 1.5rem;
    padding: 1.1rem 0;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    transition: all 0.15s;
  }
  .article-item:last-child { border-bottom: none; }
  .article-item:hover .article-title { color: var(--accent); }
  .article-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.3rem;
  }
  .article-cat-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .article-cat-label {
    font-size: 0.62rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
  }
  .article-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--ink);
    line-height: 1.35;
    transition: color 0.15s;
  }
  .article-time {
    font-size: 0.7rem;
    color: var(--muted);
    font-family: 'JetBrains Mono', monospace;
    white-space: nowrap;
    align-self: center;
  }
  .article-arrow {
    font-size: 0.75rem;
    color: var(--muted);
    align-self: center;
    transition: transform 0.15s, color 0.15s;
  }
  .article-item:hover .article-arrow { transform: translateX(3px); color: var(--accent); }

  /* ── FOOTER CTA ── */
  .footer-cta {
    background: var(--ink);
    padding: 5rem 1.5rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .footer-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 500px;
    height: 300px;
    border-radius: 50%;
    background: radial-gradient(ellipse, rgba(229,123,60,0.15) 0%, transparent 70%);
    filter: blur(60px);
    pointer-events: none;
  }
  .footer-eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.62rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--accent);
    margin-bottom: 1rem;
  }
  .footer-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 900;
    color: white;
    line-height: 1.1;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }
  .footer-sub {
    font-size: 0.92rem;
    color: #9CA3AF;
    max-width: 380px;
    margin: 0 auto 2rem;
    line-height: 1.65;
  }
  .footer-btn {
    display: inline-block;
    background: var(--accent);
    color: white;
    font-weight: 700;
    font-size: 0.9rem;
    padding: 0.875rem 2.25rem;
    border-radius: var(--radius);
    text-decoration: none;
    transition: opacity 0.15s;
  }
  .footer-btn:hover { opacity: 0.88; }
  .site-footer {
    background: #0D0D0D;
    padding: 1.25rem;
    text-align: center;
    border-top: 1px solid rgba(255,255,255,0.05);
    font-size: 0.78rem;
    color: #6B7280;
  }
  .site-footer a { color: var(--accent); text-decoration: none; }

  /* ── RESPONSIVE ── */
  @media (max-width: 860px) {
    .menu-inner { grid-template-columns: 1fr; gap: 1.5rem; }
    .menu-header { position: static; }
    .nav-menu { display: none; }
    .nav-hamburger { display: flex; }
  }
  @media (max-width: 560px) {
    .hero { padding: 3.5rem 1.25rem 3rem; }
    .featured-card { padding: 1.75rem; }
    .menu-section { padding: 3rem 1.25rem; }
    .article-title { font-size: 0.95rem; }
  }
</style>

<!-- ── NAVIGATION ── -->
