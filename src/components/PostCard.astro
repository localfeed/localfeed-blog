---
export interface Props {
  post: {
    slug: string;
    data: {
      title: string;
      description?: string;
      category: string;
      date: Date;
      readTime?: string;
      tags: string[];
    };
  };
}

const { post } = Astro.props;
const { title, description, category, date, readTime } = post.data;

const CATEGORY_META: Record<string, { label: string; color: string }> = {
  'venue-marketing':    { label: 'Venue Marketing',     color: '#3B82F6' },
  'platform-comparison':{ label: 'Platform Comparison', color: '#EF4444' },
  'operator-insights':  { label: 'Operator Insights',   color: '#10B981' },
  'off-peak':           { label: 'Off-Peak Strategy',   color: '#8B5CF6' },
  'local-seo':          { label: 'Local Discovery',     color: '#E57B3C' },
};

const cat = CATEGORY_META[category] ?? CATEGORY_META['venue-marketing'];
const dateStr = date.toLocaleDateString('en-NZ', { day: 'numeric', month: 'short', year: 'numeric' });
---

<a href={`/blog/${post.slug}`} class="post-card">
  <div class="cat-bar" style={`background: linear-gradient(90deg, ${cat.color}, ${cat.color}80);`}></div>
  <div class="card-inner">
    <span class="cat-badge" style={`color:${cat.color};background:${cat.color}14;`}>{cat.label}</span>
    <h3 class="card-title">{title}</h3>
    {description && <p class="card-desc">{description}</p>}
    <div class="card-meta">
      <span class="meta-time">{readTime && `${readTime} min`}</span>
      <span class="meta-date">{dateStr}</span>
    </div>
  </div>
</a>

<style>
.post-card {
  display: flex;
  flex-direction: column;
  border-radius: 16px;
  overflow: hidden;
  border: 1px solid rgba(0,0,0,0.07);
  background: #fff;
  text-decoration: none;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}
.post-card:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(0,0,0,0.09);
}
.cat-bar { height: 3px; width: 100%; }
.card-inner { padding: 1.25rem; display: flex; flex-direction: column; flex: 1; }
.cat-badge {
  display: inline-block;
  font-size: 0.65rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  padding: 0.2rem 0.6rem;
  border-radius: 100px;
  margin-bottom: 0.75rem;
}
.card-title {
  font-size: 0.95rem;
  font-weight: 700;
  color: #0D0D0D;
  line-height: 1.4;
  margin-bottom: 0.5rem;
  flex: 1;
}
.post-card:hover .card-title { color: #E57B3C; }
.card-desc {
  font-size: 0.82rem;
  color: #6B7280;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 1rem;
}
.card-meta {
  display: flex;
  justify-content: space-between;
  font-size: 0.75rem;
  color: #9CA3AF;
  padding-top: 0.75rem;
  border-top: 1px solid rgba(0,0,0,0.05);
  margin-top: auto;
}
</style>
